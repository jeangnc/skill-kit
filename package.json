{
  "name": "@jean.gnc/skill-kit",
  "version": "0.3.1",
  "type": "module",
  "description": "Typed framework for authoring Claude Code skills: schema, placeholder engine, and compile pipeline.",
  "license": "MIT",
  "author": "Jean Gonçalves <jean.gnc@gmail.com>",
  "homepage": "https://github.com/jeangnc/skill-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeangnc/skill-kit.git"
  },
  "bugs": {
    "url": "https://github.com/jeangnc/skill-kit/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "plugin",
    "markdown",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "skill-kit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "imports": {
    "#skill-kit": "./src/index.ts"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit && prettier --check 'src/**/*.ts' && eslint 'src/**/*.ts'",
    "lint:format": "prettier --check 'src/**/*.ts'",
    "lint:code": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "tsx --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
