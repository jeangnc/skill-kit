{
  "name": "skill-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Typed framework for authoring Claude Code skills: schema, placeholder engine, and compile pipeline.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "#skill-kit": "./src/index.ts"
  },
  "scripts": {
    "lint": "tsc --noEmit && prettier --check 'src/**/*.ts' && eslint 'src/**/*.ts'",
    "lint:format": "prettier --check 'src/**/*.ts'",
    "lint:code": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "tsx --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  }
}
