{
  "name": "@jean.gnc/harness-kit",
  "version": "0.5.1",
  "type": "module",
  "description": "Build your own multi-agent harness: typed toolkit for authoring plugins (skills, agents, commands, hooks) and shipping them to Claude Code and Codex from a single source tree.",
  "license": "MIT",
  "author": "Jean Gonçalves <jean.gnc@gmail.com>",
  "homepage": "https://github.com/jeangnc/harness-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeangnc/harness-kit.git"
  },
  "bugs": {
    "url": "https://github.com/jeangnc/harness-kit/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "agent",
    "multi-agent",
    "harness",
    "marketplace",
    "plugin",
    "skills",
    "markdown",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "harness-kit": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "imports": {
    "#harness-kit": "./src/index.ts"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit && prettier --check 'src/**/*.ts' && eslint 'src/**/*.ts'",
    "lint:format": "prettier --check 'src/**/*.ts'",
    "lint:code": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "tsx --test 'src/**/*.test.ts'",
    "test:coverage": "c8 --reporter=text --reporter=lcov tsx --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "check": "pnpm lint && pnpm test",
    "prepare": "husky",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "citty": "^0.2.2",
    "js-yaml": "^4.1.1",
    "markdownlint-cli2": "^0.18.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "c8": "^11.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.27.0"
}
